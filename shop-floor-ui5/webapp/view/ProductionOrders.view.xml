<mvc:View
    controllerName="zshopfloor.controller.ProductionOrders"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.ui.layout.form"
    displayBlock="true">

    <Page
        id="idProductionOrdersPage"
        title="Production Orders"
        showNavButton="true"
        navButtonPress="onNavBack"
        class="sfPage">

        <content>
            <VBox class="sfTableContainer">

                <!-- ── Filter Bar ── -->
                <Toolbar class="sfFilterBar">
                    <SearchField
                        id="idProdSearchField"
                        placeholder="Search by Order No, Material, Plant…"
                        search="onSearch"
                        liveChange="onSearchLive"
                        width="22rem"
                        class="sfSearchField"/>
                    <Select
                        id="idProdPlantFilter"
                        change="onPlantFilterChange"
                        class="sfFilterSelect"
                        width="10rem">
                        <items>
                            <core:Item key="" text="All Plants"/>
                            <core:Item key="0001" text="Plant 0001"/>
                            <core:Item key="1003" text="Plant 1003"/>
                        </items>
                    </Select>
                    <Select
                        id="idProdOrderTypeFilter"
                        change="onOrderTypeFilterChange"
                        class="sfFilterSelect"
                        width="11rem">
                        <items>
                            <core:Item key="" text="All Order Types"/>
                            <core:Item key="PP01" text="PP01"/>
                            <core:Item key="PM02" text="PM02"/>
                        </items>
                    </Select>
                    <Button
                        text="Clear"
                        icon="sap-icon://clear-filter"
                        press="onClearFilters"
                        type="Transparent"
                        class="sfClearBtn"/>
                    <ToolbarSpacer/>
                    <Button
                        text="Refresh"
                        icon="sap-icon://refresh"
                        press="onRefresh"
                        type="Transparent"
                        class="sfRefreshBtn"/>
                </Toolbar>

                <!-- Record count -->
                <Toolbar class="sfInfoBar">
                    <Text id="idProdRecordCount" text="Loading..." class="sfRecordCount"/>
                    <ToolbarSpacer/>
                </Toolbar>

                <!-- Table bound to LOCAL JSON model -->
                <Table
                    id="idProductionOrdersTable"
                    items="{localModel>/items}"
                    growing="true"
                    growingThreshold="20"
                    growingScrollToLoad="true"
                    noDataText="No production orders found"
                    busyIndicatorDelay="0"
                    class="sfTable"
                    updateFinished="onUpdateFinished"
                    mode="None"
                    selectionChange="onSelectionChange"
                    fixedLayout="false">

                    <headerToolbar>
                        <Toolbar class="sfTableHeader">
                            <Title text="Production Orders" level="H4" class="sfTableTitle"/>
                            <ToolbarSpacer/>
                        </Toolbar>
                    </headerToolbar>

                    <columns>
                        <Column width="11rem">
                            <header><Label text="Production Order" class="sfColHeader"/></header>
                        </Column>
                        <Column width="11rem">
                            <header><Label text="Material" class="sfColHeader"/></header>
                        </Column>
                        <Column width="8rem">
                            <header><Label text="Plant" class="sfColHeader"/></header>
                        </Column>
                        <Column width="11rem">
                            <header><Label text="Scheduled Start" class="sfColHeader"/></header>
                        </Column>
                        <Column width="11rem">
                            <header><Label text="Scheduled Finish" class="sfColHeader"/></header>
                        </Column>
                    </columns>

                    <items>
                        <ColumnListItem
                            type="Navigation"
                            press="onRowPress">
                            <cells>
                                <ObjectIdentifier
                                    title="{localModel>Aufnr}"
                                    text="{localModel>Auart}"/>
                                <Text text="{localModel>Matnr}"/>
                                <Text text="{localModel>Werks}"/>
                                <Text text="{
                                    path: 'localModel>Gstrp',
                                    formatter: '.formatter.formatDate'
                                }"/>
                                <Text text="{
                                    path: 'localModel>Gltrp',
                                    formatter: '.formatter.formatDate'
                                }"/>
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </VBox>
        </content>

        <!-- Order Detail Dialog -->
        <dependents>
            <Dialog id="idOrderDetailDialog" title="Production Order Details" contentWidth="450px">
                <content>
                    <f:SimpleForm editable="false" layout="ResponsiveGridLayout"
                        labelSpanL="4" labelSpanM="4" columnsL="1" columnsM="1">
                        <f:content>
                            <core:Title text="Order Information"/>
                            <Label text="Production Order"/>
                            <Text text="{detailModel>/Aufnr}"/>
                            <Label text="Order Type"/>
                            <Text text="{detailModel>/Auart}"/>
                            <Label text="Material"/>
                            <Text text="{detailModel>/Matnr}"/>
                            <Label text="Material Description"/>
                            <Text text="{detailModel>/Maktx}"/>
                            <Label text="Plant"/>
                            <Text text="{detailModel>/Werks}"/>
                            <core:Title text="Dates"/>
                            <Label text="Scheduled Start"/>
                            <Text text="{path: 'detailModel>/Gstrp', formatter: '.formatter.formatDate'}"/>
                            <Label text="Scheduled Finish"/>
                            <Text text="{path: 'detailModel>/Gltrp', formatter: '.formatter.formatDate'}"/>
                            <Label text="System Status"/>
                            <ObjectStatus
                                text="{detailModel>/Status}"
                                state="{path: 'detailModel>/Status', formatter: '.formatter.statusToState'}"
                                inverted="true"/>
                        </f:content>
                    </f:SimpleForm>
                </content>
                <beginButton>
                    <Button text="Close" press="onCloseDialog" type="Emphasized"/>
                </beginButton>
            </Dialog>
        </dependents>

        <footer>
            <Toolbar class="sfFooterBar">
                <ToolbarSpacer/>
                <Text id="idProdFooterText" text="" class="sfFooterText"/>
            </Toolbar>
        </footer>

    </Page>
</mvc:View>